{
  "name": "CRM Base",
  "id": "crm_base",
  "description": "Template essenziale per la gestione clienti, lead e attività.",
  "category": "Sales",
  "models": [
    {
      "name": "customer",
      "title": "Cliente",
      "table": "crm_customers",
      "fields": [
        {"name": "name", "title": "Ragione Sociale", "type": "string", "required": true},
        {"name": "email", "title": "Email", "type": "string"},
        {"name": "phone", "title": "Telefono", "type": "string"},
        {"name": "vat_number", "title": "Partita IVA", "type": "string"}
      ]
    },
    {
      "name": "lead",
      "title": "Lead",
      "table": "crm_leads",
      "fields": [
        {"name": "name", "title": "Nome Contatto", "type": "string", "required": true},
        {"name": "company", "title": "Azienda", "type": "string"},
        {"name": "email", "title": "Email", "type": "string"},
        {"name": "status", "title": "Stato", "type": "select", "options": ["nuovo", "contattato", "qualificato", "perso"]}
      ]
    },
    {
      "name": "activity",
      "title": "Attività",
      "table": "crm_activities",
      "fields": [
        {"name": "subject", "title": "Oggetto", "type": "string", "required": true},
        {"name": "date", "title": "Data", "type": "date"},
        {"name": "type", "title": "Tipo", "type": "select", "options": ["chiamata", "email", "riunione"]},
        {"name": "notes", "title": "Note", "type": "text"}
      ]
    }
  ],
  "views": [
    {
      "name": "customer_list",
      "model": "customer",
      "type": "list",
      "title": "Lista Clienti"
    },
    {
      "name": "lead_kanban",
      "model": "lead",
      "type": "kanban",
      "title": "Pipeline Lead",
      "config": {"groupBy": "status"}
    }
  ]
}
