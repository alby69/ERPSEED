{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://erpseed.io/schemas/business_rule.json",
  "title": "Business Rule Schema",
  "description": "Schema for defining business rules in ERPSEED",
  "type": "object",
  "required": ["name", "technical_name", "model", "type", "actions"],
  "properties": {
    "name": {"type": "string"},
    "technical_name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "model": {"type": "string"},
    "type": {"type": "string", "enum": ["validation", "computation", "action", "constraint"]},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "operator"],
        "properties": {
          "field": {"type": "string"},
          "operator": {"type": "string", "enum": ["==", "!=", ">", "<", ">=", "<=", "in", "not_in", "like", "is_null", "is_not_null"]},
          "value": {}
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"type": "string"},
          "params": {"type": "object"}
        }
      }
    },
    "trigger": {"type": "string", "enum": ["on_save", "on_create", "on_delete", "on_change", "manual"]},
    "priority": {"type": "integer", "default": 0},
    "enabled": {"type": "boolean", "default": true},
    "settings": {"type": "object"}
  }
}
