{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://erpseed.io/schemas/project.json",
  "title": "Project Schema",
  "description": "Schema for defining ERP projects in ERPSEED",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {"type": "string"},
    "version": {"type": "string", "default": "1.0.0"},
    "description": {"type": "string"},
    "models": {"type": "array", "items": {"type": "object"}},
    "blocks": {"type": "array", "items": {"type": "object"}},
    "workflows": {"type": "array", "items": {"type": "object"}},
    "business_rules": {"type": "array", "items": {"type": "object"}},
    "settings": {
      "type": "object",
      "properties": {
        "database": {
          "type": "object",
          "properties": {
            "type": {"type": "string", "enum": ["sqlite", "postgresql"]},
            "name": {"type": "string"}
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"}
          }
        },
        "theme": {
          "type": "object",
          "properties": {
            "name": {"type": "string"}
          }
        }
      }
    }
  }
}
