{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://erpseed.io/schemas/model.json",
  "title": "Model Schema",
  "description": "Schema for defining data models in ERPSEED",
  "type": "object",
  "required": ["name", "technical_name", "fields"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the model"
    },
    "technical_name": {
      "type": "string",
      "description": "Technical identifier (snake_case)",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "table_name": {
      "type": "string",
      "description": "Database table name"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title"
    },
    "description": {
      "type": "string",
      "description": "Model description"
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/field"
      },
      "minItems": 1
    },
    "permissions": {
      "type": "object",
      "properties": {
        "read": {
          "type": "array",
          "items": {"type": "string"}
        },
        "write": {
          "type": "array",
          "items": {"type": "string"}
        },
        "delete": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "settings": {
      "type": "object",
      "description": "Additional model settings"
    }
  },
  "definitions": {
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Field name (snake_case)"
        },
        "type": {
          "type": "string",
          "enum": ["string", "text", "integer", "float", "boolean", "date", "datetime", "decimal", "binary", "many2one", "many2many", "one2many", "selection", "json"],
          "description": "Field type"
        },
        "title": {
          "type": "string",
          "description": "Field display title"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "unique": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "type": ["string", "number", "boolean", "null"],
          "description": "Default value"
        },
        "min_length": {
          "type": "integer",
          "minimum": 0
        },
        "max_length": {
          "type": "integer",
          "minimum": 1
        },
        "min_value": {
          "type": "number"
        },
        "max_value": {
          "type": "number"
        },
        "choices": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Available choices for selection fields"
        },
        "related_model": {
          "type": "string",
          "description": "Related model for relation fields"
        },
        "on_delete": {
          "type": "string",
          "enum": ["cascade", "set_null", "restrict", "no_action"],
          "default": "no_action"
        },
        "widget": {
          "type": "string",
          "default": "text"
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "editable": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
